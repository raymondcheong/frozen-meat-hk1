# 阿里雲百煉 API Key（千問）
# 取得: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# 可選：模型名稱（需支持聯網搜索，如 qwen-plus、qwen-max）
# QWEN_MODEL=qwen-plus

# 可選：每日 AI 情報條數 / 保留天數
# AI_NEWS_LIMIT=10
# AI_NEWS_RETENTION_DAYS=3

# FRED API Key（海產指數自動更新，免費申請）
# https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your-fred-api-key-here
